# VEGA AI — Environment Variables
# 100% FREE services only. All keys below are optional (local models work without any).
# Copy this file to .env and fill in the keys you want to use.

# ─── Text-to-Video / Image (ALL FREE) ────────────────────────────
# HuggingFace — Free unlimited via Inference API
# Get free token at: https://huggingface.co/settings/tokens
HF_API_KEY=

# ZSky AI — FREE 1080p + audio, no credit card
# https://zsky.ai/signup
ZSKY_API_KEY=

# JSON2Video — FREE 600 seconds/month, no credit card
# https://json2video.com/get-api-key/
JSON2VIDEO_API_KEY=

# Luma Dream Machine — FREE 5 videos/month
# https://lumalabs.ai/dream-machine/api
LUMA_API_KEY=

# ─── Voice (optional, free) ──────────────────────────────────────
# Porcupine wake word — free tier at https://picovoice.ai/
PORCUPINE_ACCESS_KEY=

# ─── Config Overrides (optional) ─────────────────────────────────
# VEGA_MODELS_DEFAULT_LOCAL=qwen3:30b-a3b
# VEGA_HUD_PORT=8888
# VEGA_VOICE_ENABLED=true
